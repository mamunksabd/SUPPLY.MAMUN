<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ACGC Premium Manpower Website Preview</title>
<meta name="description" content="Accredited Choice General Contracting Est. premium manpower supply and industrial support website preview with Megh Balika AI assistant.">
<style>
:root{
  --bg:#07111f;
  --bg2:#0b1d39;
  --card:#ffffff;
  --text:#0f172a;
  --muted:#64748b;
  --line:rgba(15,23,42,.08);
  --blue:#0b8fe3;
  --blue2:#0a6ec8;
  --soft:#eef7ff;
  --green:#19c37d;
  --shadow:0 18px 50px rgba(2,12,27,.14);
  --radius:26px;
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{
  margin:0;
  font-family:Arial, Helvetica, sans-serif;
  background:linear-gradient(180deg,#eef4fb 0%,#f8fbff 100%);
  color:var(--text);
}
a{text-decoration:none;color:inherit}
img{max-width:100%;display:block}
.container{width:min(1220px,calc(100% - 28px));margin:0 auto}
.topbar{
  position:sticky;top:0;z-index:1000;
  background:linear-gradient(135deg,#03112b,#071e4e 58%,#082962);
  box-shadow:0 10px 30px rgba(2,18,49,.2)
}
.nav{
  display:flex;align-items:center;justify-content:space-between;gap:18px;padding:16px 0
}
.brand{display:flex;align-items:center;gap:14px;min-width:0}
.brand-logo{
  width:72px;height:72px;border-radius:20px;
  background:linear-gradient(180deg,#14a0ff,#0b7fd4);
  display:grid;place-items:center;overflow:hidden;flex:0 0 auto;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.22)
}
.brand-logo img{width:42px;height:42px;object-fit:contain}
.brand-text h1{margin:0;color:#fff;font-size:20px;line-height:1.05;text-transform:uppercase}
.brand-text p{margin:6px 0 0;color:#28a9ff;font-size:12px;letter-spacing:3px;text-transform:uppercase}
.menu{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.menu a{color:rgba(255,255,255,.92);font-size:13px;font-weight:700;padding:10px 12px;border-radius:999px;text-transform:uppercase}
.menu a:hover{background:rgba(255,255,255,.08)}
.menu-btn{display:none;width:50px;height:50px;border:0;border-radius:16px;background:rgba(255,255,255,.08);color:#fff;font-size:28px}
.hero{padding:28px 0 22px}
.hero-box{
  background:linear-gradient(135deg,#041430,#071e4e 60%,#0a2d66);
  border-radius:34px;color:#fff;overflow:hidden;box-shadow:0 28px 70px rgba(4,20,48,.18);
  display:grid;grid-template-columns:1.12fr .88fr;gap:26px;padding:30px;position:relative
}
.hero-box:before{
  content:"";position:absolute;right:-120px;top:-120px;width:340px;height:340px;border-radius:50%;
  background:radial-gradient(circle,rgba(11,143,227,.28),rgba(11,143,227,0));pointer-events:none
}
.badge{
  display:inline-flex;align-items:center;gap:10px;padding:10px 15px;border-radius:999px;
  background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.12);font-size:12px;font-weight:700;
  text-transform:uppercase;letter-spacing:.8px;margin-bottom:18px
}
.hero h2{margin:0 0 14px;font-size:clamp(34px,4vw,58px);line-height:1.04}
.hero p{margin:0;color:rgba(255,255,255,.84);font-size:16px;max-width:700px}
.hero-actions{display:flex;gap:14px;flex-wrap:wrap;margin-top:24px}
.btn{
  border:0;border-radius:999px;padding:15px 24px;font-weight:700;font-size:14px;cursor:pointer;
  transition:.18s transform,.18s background,.18s box-shadow;display:inline-flex;align-items:center;justify-content:center
}
.btn:hover{transform:translateY(-1px)}
.btn-primary{background:#fff;color:#041430;box-shadow:0 16px 30px rgba(255,255,255,.15)}
.btn-primary:hover{background:#eaf5ff}
.btn-outline{background:transparent;color:#fff;border:2px solid rgba(255,255,255,.18)}
.btn-outline:hover{background:rgba(255,255,255,.08)}
.hero-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:24px}
.stat{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);padding:18px;border-radius:20px
}
.stat strong{display:block;font-size:22px;margin-bottom:4px}
.stat span{font-size:12px;color:rgba(255,255,255,.76);text-transform:uppercase;letter-spacing:1px}
.profile-card{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.1);border-radius:30px;padding:18px;
  display:grid;align-content:start;gap:16px;position:relative;z-index:1
}
.profile-photo{
  border-radius:26px;overflow:hidden;background:rgba(255,255,255,.08);border:5px solid rgba(255,255,255,.14)
}
.profile-photo img{width:100%;aspect-ratio:4/5.2;object-fit:cover;object-position:center top}
.chip{
  width:max-content;margin:0 auto;padding:8px 14px;border-radius:999px;background:rgba(255,255,255,.1);
  color:#dceeff;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px
}
.profile-card h3{margin:0;text-align:center;font-size:28px}
.profile-card .role{margin:0;text-align:center;color:#dceeff;font-weight:700;font-size:16px;line-height:1.45}
.profile-list{display:grid;gap:12px;color:rgba(255,255,255,.9);font-size:15px}
.section{padding:16px 0 0}
.section-head{display:flex;justify-content:space-between;align-items:end;gap:20px;margin-bottom:18px}
.section-head h2{margin:0;font-size:clamp(28px,3vw,40px);color:#102144}
.section-head p{margin:0;max-width:760px;color:var(--muted);line-height:1.6}
.grid-2,.grid-3,.grid-4{display:grid;gap:18px}
.grid-2{grid-template-columns:repeat(2,1fr)}
.grid-3{grid-template-columns:repeat(3,1fr)}
.grid-4{grid-template-columns:repeat(4,1fr)}
.card{
  background:var(--card);border-radius:var(--radius);padding:24px;box-shadow:var(--shadow);border:1px solid var(--line)
}
.card h3,.card h4{margin:0 0 12px;color:#102144}
.card p{margin:0;color:var(--muted);line-height:1.65}
.iconbox{
  width:62px;height:62px;border-radius:18px;background:var(--soft);color:var(--blue);display:grid;place-items:center;
  font-size:28px;margin-bottom:14px
}
.list{margin:12px 0 0;padding-left:18px;color:var(--muted)}
.list li+li{margin-top:8px}
.banner-img{border-radius:22px;box-shadow:var(--shadow);width:100%}
.worker-tools{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:16px}
.worker-tools input{
  flex:1;min-width:240px;padding:15px 16px;border-radius:16px;border:1px solid rgba(15,23,42,.12);outline:none;font-size:15px
}
.worker-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.worker-item{
  background:#fff;border:1px solid rgba(15,23,42,.08);border-radius:16px;padding:14px 15px;
  box-shadow:0 10px 24px rgba(2,18,49,.05);font-size:14px;font-weight:700;color:#183153
}
.projects{display:grid;grid-template-columns:repeat(2,1fr);gap:18px}
.project-card{overflow:hidden;padding:0}
.project-card img{width:100%;aspect-ratio:1.25/1;object-fit:cover}
.project-body{padding:22px}
.project-tag{
  position:absolute;top:16px;right:16px;background:#16d163;color:#fff;padding:12px 18px;border-radius:999px;font-weight:700
}
.project-wrap{position:relative}
.license-wrap img{width:100%;max-width:420px;margin:0 auto;border-radius:22px;box-shadow:var(--shadow)}
.gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:14px}
.gallery-grid img{width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:20px;box-shadow:var(--shadow)}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.contact-list{display:grid;gap:14px}
.contact-list div{padding:16px 18px;border-radius:18px;background:#f8fbff;border:1px solid rgba(15,23,42,.06)}
.form{display:grid;gap:12px}
.form input,.form textarea{
  width:100%;padding:14px 15px;border-radius:16px;border:1px solid rgba(15,23,42,.12);outline:none;font:inherit
}
footer{margin-top:40px;background:linear-gradient(135deg,#041430,#071e4e);color:#fff;padding:34px 0}
.footer-wrap{display:flex;justify-content:space-between;align-items:center;gap:16px;flex-wrap:wrap}
.footer-wrap p{margin:0;color:rgba(255,255,255,.82)}
.footer-links{display:flex;gap:10px;flex-wrap:wrap}
.footer-links a{padding:8px 10px;border-radius:999px;color:rgba(255,255,255,.92);font-size:13px;font-weight:700}
.footer-links a:hover{background:rgba(255,255,255,.08)}
#aiToggle{
  position:fixed;right:18px;bottom:92px;width:64px;height:64px;border-radius:50%;border:0;
  background:linear-gradient(180deg,#0b8fe3,#0a73ca);color:#fff;font-size:26px;cursor:pointer;
  box-shadow:0 18px 36px rgba(11,143,227,.34);z-index:1200
}
#waFloat{
  position:fixed;right:18px;bottom:18px;width:60px;height:60px;border-radius:50%;display:grid;place-items:center;
  background:#25D366;color:#fff;font-size:28px;box-shadow:0 18px 36px rgba(37,211,102,.28);z-index:1200
}
#aiPanel{
  position:fixed;right:18px;bottom:170px;width:380px;max-width:calc(100vw - 24px);height:500px;background:#fff;border-radius:24px;
  box-shadow:0 28px 70px rgba(2,18,49,.24);overflow:hidden;border:1px solid rgba(15,23,42,.08);z-index:1201;display:none;flex-direction:column
}
#aiPanel.active{display:flex}
.aiHead{
  background:linear-gradient(135deg,#071e4e,#0b8fe3);color:#fff;padding:16px 18px;display:flex;justify-content:space-between;align-items:center;gap:10px
}
.aiHead strong{display:block;font-size:17px}
.aiHead small{color:rgba(255,255,255,.84)}
.aiClose{width:36px;height:36px;border-radius:50%;border:0;background:rgba(255,255,255,.14);color:#fff;font-size:18px;cursor:pointer}
.aiBody{flex:1;padding:14px;background:#f7fbff;overflow-y:auto;display:flex;flex-direction:column;gap:10px}
.bubble{max-width:86%;padding:12px 14px;border-radius:16px;font-size:14px;line-height:1.5;box-shadow:0 4px 10px rgba(2,18,49,.04)}
.bubble.user{align-self:flex-end;background:#dff2ff;color:#083c66;border-bottom-right-radius:6px}
.bubble.bot{align-self:flex-start;background:#fff;color:#183153;border-bottom-left-radius:6px;border:1px solid rgba(15,23,42,.06)}
.aiFoot{display:flex;gap:10px;padding:12px;border-top:1px solid rgba(15,23,42,.08);background:#fff}
.aiFoot input{flex:1;border-radius:14px;border:1px solid rgba(15,23,42,.12);padding:13px 14px;outline:none;font-size:14px}
.aiFoot button{border:0;border-radius:14px;padding:0 16px;background:#0b8fe3;color:#fff;font-weight:700;cursor:pointer}
.aiQuick{display:flex;gap:8px;flex-wrap:wrap;padding:0 12px 12px;background:#fff}
.aiQuick button{border:1px solid rgba(15,23,42,.08);background:#f8fbff;border-radius:999px;padding:9px 12px;font-size:12px;font-weight:700;cursor:pointer;color:#0f3b63}
@media (max-width:1080px){
  .menu{display:none;position:absolute;left:14px;right:14px;top:88px;background:#071e4e;border-radius:22px;padding:10px;box-shadow:0 20px 44px rgba(2,18,49,.24)}
  .menu.active{display:grid;grid-template-columns:1fr}
  .menu-btn{display:grid;place-items:center}
  .hero-box,.grid-2,.grid-3,.projects,.contact-grid{grid-template-columns:1fr}
  .grid-4,.worker-grid,.gallery-grid{grid-template-columns:repeat(2,1fr)}
  .hero-stats{grid-template-columns:1fr}
}
@media (max-width:680px){
  .brand-logo{width:58px;height:58px}.brand-logo img{width:34px;height:34px}
  .brand-text h1{font-size:16px}.brand-text p{font-size:10px;letter-spacing:2px}
  .hero-box{padding:22px;border-radius:28px}
  .gallery-grid,.worker-grid,.grid-4{grid-template-columns:1fr}
  #aiPanel{left:12px;right:12px;width:auto;bottom:152px;height:58vh}
  #aiToggle{right:14px;bottom:88px}#waFloat{right:14px;bottom:14px}
}
</style>
</head>
<body>
<header class="topbar">
  <div class="container nav">
    <div class="brand">
      <div class="brand-logo"><img src="images/logo.png" alt="ACGC Logo"></div>
      <div class="brand-text">
        <h1>Abdullah Al Mamun</h1>
        <p>Contracting Est.</p>
      </div>
    </div>
    <button class="menu-btn" id="menuBtn">☰</button>
    <nav class="menu" id="menu">
      <a href="#home">Home</a>
      <a href="#about">About</a>
      <a href="#services">Services</a>
      <a href="#workers">Workers</a>
      <a href="#projects">Projects</a>
      <a href="#legal">Legal</a>
      <a href="#gallery">Gallery</a>
      <a href="#contact">Contact</a>
    </nav>
  </div>
</header>

<main>
  <section class="hero" id="home">
    <div class="container hero-box">
      <div>
        <div class="badge">Premium manpower and industrial support in KSA & UAE</div>
        <h2>100% professional manpower website with premium presentation and smart client handling.</h2>
        <p>Accredited Choice General Contracting Est. provides skilled, semi-skilled, technical, and general manpower for construction, shutdown, maintenance, logistics, and industrial operations across Saudi Arabia and UAE.</p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="https://wa.me/966571371214?text=Assalamu%20Alaikum.%20I%20need%20manpower%20support." target="_blank" rel="noopener noreferrer">Request Manpower</a>
          <button class="btn btn-outline" onclick="document.getElementById('aiPanel').classList.add('active');startGreeting()">Talk to Megh Balika</button>
        </div>
        <div class="hero-stats">
          <div class="stat"><strong>24 to 48H</strong><span>Fast Mobilization</span></div>
          <div class="stat"><strong>100%</strong><span>Professional Coordination</span></div>
          <div class="stat"><strong>102+</strong><span>Worker Categories</span></div>
        </div>
      </div>
      <div class="profile-card">
        <div class="profile-photo"><img src="images/profile-full.jpg" alt="Abdullah Al Mamun" title="Managing Director profile photo"></div>
        <div class="chip">Managing Director</div>
        <h3>Abdullah Al Mamun</h3>
        <p class="role">Manpower Supply & Contracting Specialist</p>
        <div class="profile-list">
          <div>Operations: Saudi Arabia & UAE</div>
          <div>Company: Accredited Choice General Contracting Est.</div>
          <div>Focus: Manpower, industrial support, shutdown, and maintenance</div>
          <div>Client handling with direct professional communication</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="about">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>About Company</h2>
          <p>This preview is designed as a modern manpower website with stronger premium quality, trust elements, image-based validation, smart AI presentation, and clear business positioning.</p>
        </div>
      </div>
      <div class="grid-2">
        <div class="card">
          <h3>Company Overview</h3>
          <p>Accredited Choice General Contracting Est. is positioned as a dependable manpower and industrial support company serving contractors, projects, shutdown teams, and ongoing maintenance operations.</p>
          <ul class="list">
            <li>Fast response for project manpower requests</li>
            <li>Clear client communication and quotation guidance</li>
            <li>Premium business presentation for Saudi market clients</li>
          </ul>
        </div>
        <div class="card">
          <h3>Vision & Mission</h3>
          <ul class="list">
            <li><strong>Vision:</strong> To become a trusted manpower and industrial solutions partner in the Gulf region.</li>
            <li><strong>Mission:</strong> To provide the right workforce at the right time with strong professional support.</li>
            <li><strong>Core Values:</strong> Trust, commitment, quality, speed, and client satisfaction.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="services">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>Our Services</h2>
          <p>Everything is arranged for premium client understanding and stronger conversion.</p>
        </div>
      </div>
      <div class="grid-4">
        <div class="card"><div class="iconbox">👷</div><h4>Manpower Supply</h4><p>Skilled, semi-skilled, technical, and general workers across multiple categories.</p></div>
        <div class="card"><div class="iconbox">🏗️</div><h4>Construction Support</h4><p>Foremen, fabricators, welders, scaffolders, electricians, and maintenance teams.</p></div>
        <div class="card"><div class="iconbox">⚙️</div><h4>Industrial Support</h4><p>Shutdown, operations, maintenance, and worksite coordination support.</p></div>
        <div class="card"><div class="iconbox">🚚</div><h4>Logistics & Drivers</h4><p>Heavy drivers, operators, helpers, and transport-related manpower support.</p></div>
      </div>
    </div>
  </section>

  <section class="section" id="workers">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>Worker Categories</h2>
          <p>Your original categories visual has been kept as a premium trust section and also supported by searchable worker tiles.</p>
        </div>
      </div>
      <div class="card" style="margin-bottom:18px">
        <img class="banner-img" src="images/categories.jpg" alt="Worker categories">
      </div>
      <div class="worker-tools">
        <input type="text" id="workerSearch" placeholder="Search worker category...">
      </div>
      <div class="worker-grid" id="workerGrid"></div>
    </div>
  </section>

  <section class="section" id="projects">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>Project Experience</h2>
          <p>Premium project card layout for stronger client trust and industrial credibility.</p>
        </div>
      </div>
      <div class="projects">
        <div class="card project-card">
          <div class="project-wrap">
            <img src="images/site1.jpg" alt="Industrial project">
            <div class="project-tag">Ongoing</div>
          </div>
          <div class="project-body">
            <h3>Jubail Industrial City Maintenance</h3>
            <p><strong style="color:#0b8fe3">SABIC</strong></p>
            <ul class="list">
              <li>Location: Jubail, KSA</li>
              <li>Duration: 2019 - Present</li>
              <li>150+ technicians and support manpower</li>
            </ul>
          </div>
        </div>
        <div class="card project-card">
          <div class="project-wrap">
            <img src="images/offshore.jpg" alt="Offshore support">
          </div>
          <div class="project-body">
            <h3>Offshore & Electrical Equipment Support</h3>
            <p>Specialized visual company service presentation for industrial and offshore client confidence.</p>
            <ul class="list">
              <li>Offshore operations support image ready</li>
              <li>Electrical equipment support branding</li>
              <li>Premium corporate service presentation</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" id="legal">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>Legal & License</h2>
          <p>Official document image area that adds strong confidence for client review.</p>
        </div>
      </div>
      <div class="card license-wrap">
        <img src="images/license.jpg" alt="VAT registration certificate">
      </div>
    </div>
  </section>

  <section class="section" id="gallery">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>Gallery Preview</h2>
          <p>Real business photos, profile identity, and industrial visuals for a premium final impression.</p>
        </div>
      </div>
      <div class="gallery-grid">
        <img src="images/profile-full.jpg" alt="Managing director photo">
        <img src="images/offshore.jpg" alt="Offshore visual">
        <img src="images/categories.jpg" alt="Worker categories visual">
        <img src="images/license.jpg" alt="License visual">
      </div>
    </div>
  </section>

  <section class="section" id="contact">
    <div class="container">
      <div class="section-head">
        <div>
          <h2>Contact & Inquiry</h2>
          <p>Designed to help clients reach you quickly for manpower requests and quotation support.</p>
        </div>
      </div>
      <div class="contact-grid">
        <div class="card contact-list">
          <div><strong>Company</strong><br>Accredited Choice General Contracting Est.</div>
          <div><strong>Managing Director</strong><br>Abdullah Al Mamun</div>
          <div><strong>Phone / WhatsApp</strong><br><a href="https://wa.me/966571371214?text=Assalamu%20Alaikum.%20I%20need%20manpower%20support." target="_blank" rel="noopener noreferrer">+966 57 137 1214</a></div>
          <div><strong>Email</strong><br><a href="mailto:supply.mamun@jmail.com">supply.mamun@jmail.com</a></div>
          <div><strong>Location</strong><br>Al Jubail, Kingdom of Saudi Arabia</div>
        </div>
        <div class="card">
          <h3>Quick Inquiry</h3>
          <form class="form" action="https://formspree.io/f/your-id" method="POST">
            <input type="text" name="name" placeholder="Your Name" required>
            <input type="email" name="email" placeholder="Business Email" required>
            <textarea name="message" rows="5" placeholder="Required manpower category, quantity, duty hours, project location" required></textarea>
            <button class="btn btn-primary" type="submit">Send Inquiry</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</main>

<button id="aiToggle" aria-label="Open AI">💬</button>
<a id="waFloat" href="https://wa.me/966571371214?text=Assalamu%20Alaikum.%20I%20need%20manpower%20support." target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">🟢</a>

<div id="aiPanel">
  <div class="aiHead">
    <div>
      <strong>Megh Balika AI</strong>
      <small>Sweet female voice guided assistant</small>
    </div>
    <button class="aiClose" id="aiClose">✕</button>
  </div>
  <div class="aiBody" id="aiBody"></div>
  <div class="aiQuick">
    <button type="button" data-q="Tell me about your company">Company</button>
    <button type="button" data-q="Tell me about your vision and mission">Vision</button>
    <button type="button" data-q="I need manpower">Manpower</button>
    <button type="button" data-q="Tell me about your worker categories">Workers</button>
    <button type="button" data-q="Tell me about your projects">Projects</button>
    <button type="button" data-q="I need a quotation">Quotation</button>
    <button type="button" data-q="Give me contact details">Contact</button>
  </div>
  <div class="aiFoot">
    <input type="text" id="aiInput" placeholder="Ask about company, manpower, quote, contact, mission, vision">
    <button type="button" id="aiSend">Send</button>
  </div>
</div>

<footer>
  <div class="container footer-wrap">
    <p>© 2026 Accredited Choice General Contracting Est. All rights reserved.</p>
    <div class="footer-links">
      <a href="#home">Home</a>
      <a href="#services">Services</a>
      <a href="#workers">Workers</a>
      <a href="#contact">Contact</a>
    </div>
  </div>
</footer>

<script>
const CONFIG = {
  apiBase: '/api',
  useBackendAi: true,
  useBackendTts: true,
  formspreeEndpoint: 'https://formspree.io/f/your-id'
};

const company = {
  assistantName: 'Megh Balika',
  companyName: 'Accredited Choice General Contracting Est.',
  owner: 'Abdullah Al Mamun',
  role: 'Managing Director',
  phone: '+966 57 137 1214',
  email: 'supply.mamun@jmail.com',
  location: 'Al Jubail, Kingdom of Saudi Arabia',
  operations: 'Saudi Arabia and UAE',
  mission: 'To provide professional manpower support with proper coordination, faster response, and strong client service.',
  vision: 'To become a trusted manpower and industrial support partner in the GCC region.',
  services: 'manpower supply, industrial support, shutdown support, construction support, logistics manpower, and project coordination.',
  profileImage: 'images/profile-full.jpg',
  supportedLanguages: 'English, Arabic, Bengali, Korean, and Chinese',
  workerSummary: 'More than 102 categories including engineers, supervisors, inspectors, electricians, welders, scaffolders, riggers, operators, drivers, technicians, helpers, and general labor.',
  clientHandling: 'Polite greeting, requirement collection, category suggestion, quotation guidance, company introduction, and WhatsApp handoff.',
  projects: [
    'Jubail Industrial City Maintenance Support',
    'Offshore and Electrical Equipment Support',
    'Construction and shutdown manpower coordination for industrial clients'
  ]
};

const workerCategories = [
  'Project Managers','Construction Managers','Civil Engineers','Mechanical Engineers','Electrical Engineers','Instrumentation Engineers','Planning Engineers','Piping Engineers','QA/QC Engineers','Safety Officers','Safety Inspectors','Weld Inspectors','Quantity Surveyors','Land Surveyors','Draftsman (AutoCAD)','Draftsman (3D)','Document Controllers','Office Assistants','Store Keepers','Time Keepers','Foreman (Civil)','Foreman (Electrical)','Foreman (Mechanical)','Foreman (Piping)','Mason (Brick/Block)','Plasterer','Tile Setter','Carpenter (Shuttering)','Carpenter (Finishing)','Steel Fixer','Electrician (Building)','Electrician (Industrial)','Plumber','Pipe Fitter','Welder (6G/TIG/ARC)','Welder (Gas)','Painter (Building)','Painter (Industrial)','Scaffolder','Rigger','Crane Operator','Excavator Operator','JCB Operator','Loader Operator','Forklift Operator','Truck Driver (Heavy)','Driver (Light)','Mechanic (Heavy Equipment)','Mechanic (Auto)','AC Technician','HVAC Technician','Ductman','Insulator','Fabricator (Steel)','Erector (Steel)','Sand Blaster','Grinder','Gas Cutter','CNC Operator','Lathe Operator','Pump Operator','Generator Operator','Fire Fighting Technician','IT Technician','CCTV Technician','Network Engineer','Architect','Interior Designer','Structural Engineer','Purchasing Officer','Public Relations Officer (PRO)','HR Coordinator','Accountant','Receptionist','Camp Boss','Cook','Assistant Cook','Waiter','Laundry Man','Security Guard','Watchman','Gardener','Landscape Designer','Pool Technician','Road Worker','Asphalt Worker','Concrete Mixer Operator','Laboratory Technician (Civil)','Surveyor Helper','Concrete Pump Operator','Batching Plant Operator','Trailer Driver','Bus Driver','Heavy Bus Driver','Material Coordinator','Procurement Manager','Logistics Coordinator','General Labor','Helper','Cleaner','Wall Painter','Ceiling Technician','Glass Fitter','Aluminum Fabricator'
];

const workerGrid = document.getElementById('workerGrid');
const workerSearch = document.getElementById('workerSearch');
const menuBtn = document.getElementById('menuBtn');
const menu = document.getElementById('menu');
const aiPanel = document.getElementById('aiPanel');
const aiToggle = document.getElementById('aiToggle');
const aiClose = document.getElementById('aiClose');
const aiBody = document.getElementById('aiBody');
const aiInput = document.getElementById('aiInput');
const aiSend = document.getElementById('aiSend');
const inquiryForm = document.querySelector('.form');

function renderWorkers(list) {
  workerGrid.innerHTML = '';
  list.forEach(item => {
    const div = document.createElement('div');
    div.className = 'worker-item';
    div.textContent = item;
    workerGrid.appendChild(div);
  });
}

function detectLanguage(text) {
  if (/[\u0980-\u09FF]/.test(text)) return 'bn';
  if (/[\u0600-\u06FF]/.test(text)) return 'ar';
  if (/[\u4E00-\u9FFF]/.test(text)) return 'zh';
  if (/[\u1100-\u11FF\u3130-\u318F\uAC00-\uD7AF]/.test(text)) return 'ko';
  return 'en';
}

function applyDirByLang(text) {
  document.body.dir = detectLanguage(text) === 'ar' ? 'rtl' : 'ltr';
}

function addBubble(text, type) {
  const div = document.createElement('div');
  div.className = 'bubble ' + type;
  div.textContent = text;
  aiBody.appendChild(div);
  aiBody.scrollTop = aiBody.scrollHeight;
}

function saveLead(text) {
  try {
    const leads = JSON.parse(localStorage.getItem('acgc_leads') || '[]');
    leads.push({ text, timestamp: Date.now() });
    localStorage.setItem('acgc_leads', JSON.stringify(leads.slice(-50)));
  } catch (e) {}
}

function pickPreferredVoice() {
  if (!('speechSynthesis' in window)) return null;
  const voices = window.speechSynthesis.getVoices();
  const patterns = [/Samantha/i,/Google UK English Female/i,/Microsoft Zira/i,/Microsoft Aria/i,/Jenny/i,/Emma/i,/Ava/i,/Female/i];
  for (const pattern of patterns) {
    const found = voices.find(v => pattern.test(v.name));
    if (found) return found;
  }
  return voices.find(v => /en-US|en-GB/i.test(v.lang)) || voices[0] || null;
}

async function speakText(text) {
  if (CONFIG.useBackendTts) {
    try {
      const res = await fetch(`${CONFIG.apiBase}/tts`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ text, language: detectLanguage(text), voice: 'female-sweet' })
      });
      if (res.ok) {
        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const audio = new Audio(url);
        audio.onended = () => URL.revokeObjectURL(url);
        await audio.play();
        return;
      }
    } catch (e) {}
  }

  if (!('speechSynthesis' in window)) return;
  window.speechSynthesis.cancel();
  const utter = new SpeechSynthesisUtterance(text);
  utter.lang = detectLanguage(text)==='ar' ? 'ar-SA' : detectLanguage(text)==='bn' ? 'bn-BD' : 'en-US';
  utter.rate = 0.96;
  utter.pitch = 1.22;
  utter.volume = 1;
  const voice = pickPreferredVoice();
  if (voice) utter.voice = voice;
  window.speechSynthesis.speak(utter);
}

function localReply(text) {
  const lang = detectLanguage(text);
  const t = text.toLowerCase();

  const replies = {
    en: {
      greeting: `Assalamu Alaikum. I am ${company.assistantName}, speaking on behalf of ${company.owner}, ${company.role} of ${company.companyName}. How may I help you professionally today?`,
      company: `${company.companyName} is managed by ${company.owner}, ${company.role}. We operate across ${company.operations}, providing ${company.services}`,
      manpower: `We provide ${company.workerSummary} Please share category, quantity, duty hours, duration, and location.`,
      workers: `Our worker capability includes ${company.workerSummary}`,
      quotation: 'Please provide category, quantity, duty hours, duration, and location. Example: 10 Welders, 10 hours daily, 3 months, Jubail.',
      contact: `You can contact ${company.owner} at ${company.phone} or ${company.email}.`,
      mission: `Our mission is: ${company.mission}`,
      vision: `Our vision is: ${company.vision}`,
      project: `Our project experience includes ${company.projects.join(', ')}.`,
      support: `I can help with ${company.clientHandling}`
    },
    bn: {
      greeting: `আসসালামু আলাইকুম, আমি ${company.assistantName}। আমি ${company.owner}, ${company.role} এর পক্ষ থেকে কথা বলছি। আজ আমি আপনাকে কীভাবে প্রফেশনালভাবে সাহায্য করতে পারি?`,
      company: `${company.companyName} কোম্পানিটি ${company.owner}, ${company.role} দ্বারা পরিচালিত। আমরা ${company.operations} জুড়ে ${company.services} প্রদান করি।`,
      manpower: `আমরা ${company.workerSummary} সরবরাহ করি। ক্যাটাগরি, সংখ্যা, ডিউটি আওয়ার, সময়কাল এবং লোকেশন জানান।`,
      workers: `আমাদের worker strength হলো: ${company.workerSummary}`,
      quotation: 'কোটেশনের জন্য ক্যাটাগরি, সংখ্যা, ডিউটি আওয়ার, সময়কাল এবং লোকেশন দিন। উদাহরণ: ১০ জন ওয়েল্ডার, ১০ ঘণ্টা, ৩ মাস, জুবাইল।',
      contact: `আপনি ${company.phone} অথবা ${company.email} এ যোগাযোগ করতে পারেন।`,
      mission: `আমাদের মিশন হলো: ${company.mission}`,
      vision: `আমাদের ভিশন হলো: ${company.vision}`,
      project: `আমাদের project experience এর মধ্যে আছে: ${company.projects.join(', ')}।`,
      support: `আমি ${company.clientHandling} বিষয়ে সাহায্য করতে পারি।`
    },
    ar: {
      greeting: `السلام عليكم، أنا ${company.assistantName}. أتحدث نيابة عن ${company.owner}، ${company.role}. كيف يمكنني مساعدتك اليوم؟`,
      company: `${company.companyName} يديرها ${company.owner} وتعمل في ${company.operations}.`,
      manpower: `نحن نوفر ${company.workerSummary}`,
      workers: `فئات العمالة لدينا تشمل ${company.workerSummary}`,
      quotation: 'لإعداد عرض السعر، يرجى تزويدنا بالفئة والعدد وساعات العمل والمدة والموقع.',
      contact: `يمكنك التواصل عبر ${company.phone} أو ${company.email}.`,
      mission: `مهمتنا هي: ${company.mission}`,
      vision: `رؤيتنا هي: ${company.vision}`,
      project: `خبراتنا تشمل ${company.projects.join('، ')}.`,
      support: 'يرجى شرح احتياجك وسأرشدك إلى الخطوة التالية.'
    },
    zh: {
      greeting: `您好，我是${company.assistantName}，代表 ${company.owner} 与您沟通。请问我可以如何为您服务？`,
      company: `${company.companyName} 由 ${company.owner} 管理，业务覆盖 ${company.operations}。`,
      manpower: `我们提供 ${company.workerSummary}`,
      workers: `我们的工种包括 ${company.workerSummary}`,
      quotation: '请提供工种、人数、工时、时长和地点，以便报价。',
      contact: `联系方式：${company.phone} / ${company.email}`,
      mission: `我们的使命是：${company.mission}`,
      vision: `我们的愿景是：${company.vision}`,
      project: `我们的项目经验包括：${company.projects.join('，')}`,
      support: '请告诉我您的需求，我会给您下一步建议。'
    },
    ko: {
      greeting: `안녕하세요, 저는 ${company.assistantName}입니다. ${company.owner} 을 대신해 안내드립니다. 무엇을 도와드릴까요?`,
      company: `${company.companyName} 는 ${company.owner} 가 운영하며 ${company.operations} 에서 활동합니다.`,
      manpower: `${company.workerSummary} 인력을 제공합니다.`,
      workers: `보유 인력 카테고리는 ${company.workerSummary}`,
      quotation: '견적을 위해 직종, 인원, 근무시간, 기간, 위치를 알려주세요.',
      contact: `연락처: ${company.phone} / ${company.email}`,
      mission: `우리의 미션은: ${company.mission}`,
      vision: `우리의 비전은: ${company.vision}`,
      project: `프로젝트 경험에는 ${company.projects.join(', ')} 가 포함됩니다.`,
      support: '요구사항을 알려주시면 다음 단계를 안내하겠습니다.'
    }
  };

  const r = replies[lang] || replies.en;

  if (t.includes('quote') || t.includes('quotation') || t.includes('price') || t.includes('rate') || t.includes('কোটেশন') || t.includes('দাম') || t.includes('عرض') || t.includes('报价') || t.includes('견적')) return r.quotation;
  if (t.includes('contact') || t.includes('phone') || t.includes('email') || t.includes('whatsapp') || t.includes('যোগাযোগ') || t.includes('اتصال') || t.includes('联系方式') || t.includes('연락')) return r.contact;
  if (t.includes('company') || t.includes('about') || t.includes('profile') || t.includes('কোম্পানি') || t.includes('شركة') || t.includes('公司') || t.includes('회사')) return r.company;
  if (t.includes('manpower') || t.includes('worker') || t.includes('labour') || t.includes('labor') || t.includes('জনবল') || t.includes('عمالة') || t.includes('工人') || t.includes('인력')) return r.manpower;
  if (t.includes('category') || t.includes('categories') || t.includes('workers') || t.includes('ক্যাটাগরি') || t.includes('工种') || t.includes('카테고리')) return r.workers;
  if (t.includes('mission') || t.includes('মিশন') || t.includes('مهمة') || t.includes('使命') || t.includes('미션')) return r.mission;
  if (t.includes('vision') || t.includes('ভিশন') || t.includes('رؤية') || t.includes('愿景') || t.includes('비전')) return r.vision;
  if (t.includes('project') || t.includes('projects') || t.includes('প্রজেক্ট') || t.includes('مشروع') || t.includes('项目') || t.includes('프로젝트')) return r.project;
  if (t.includes('problem') || t.includes('support') || t.includes('help') || t.includes('সমস্যা') || t.includes('مساعدة') || t.includes('帮助') || t.includes('도움')) return r.support;
  return r.greeting;
}

async function fetchBackendReply(text) {
  const res = await fetch(`${CONFIG.apiBase}/chat`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      message: text,
      language: detectLanguage(text),
      company
    })
  });
  if (!res.ok) throw new Error('Backend AI unavailable');
  const data = await res.json();
  return data.reply || localReply(text);
}

async function getReply(text) {
  if (CONFIG.useBackendAi) {
    try {
      return await fetchBackendReply(text);
    } catch (e) {
      return localReply(text);
    }
  }
  return localReply(text);
}

async function sendMessage() {
  const text = aiInput.value.trim();
  if (!text) return;
  applyDirByLang(text);
  addBubble(text, 'user');
  saveLead(text);
  aiInput.value = '';

  const reply = await getReply(text);
  addBubble(reply, 'bot');
  speakText(reply);
}

function startGreeting() {
  if (aiBody.dataset.started === 'yes') return;
  aiBody.dataset.started = 'yes';
  const greet = `Assalamu Alaikum. I am ${company.assistantName}, your intelligent female assistant. I am speaking on behalf of ${company.owner}, ${company.role} of ${company.companyName}. I am fully trained with company details, worker categories, project experience, quotation handling, and client support. Please tell me your requirement, I will assist you professionally.`;
  addBubble(greet, 'bot');
  speakText(greet);
}

renderWorkers(workerCategories);
workerSearch.addEventListener('input', function () {
  const value = this.value.toLowerCase().trim();
  renderWorkers(workerCategories.filter(x => x.toLowerCase().includes(value)));
});

menuBtn.addEventListener('click', () => menu.classList.toggle('active'));
menu.querySelectorAll('a').forEach(a => a.addEventListener('click', () => menu.classList.remove('active')));

aiToggle.addEventListener('click', () => {
  aiPanel.classList.toggle('active');
  if (aiPanel.classList.contains('active')) startGreeting();
});
aiClose.addEventListener('click', () => aiPanel.classList.remove('active'));

aiSend.addEventListener('click', sendMessage);
aiInput.addEventListener('keydown', e => {
  if (e.key === 'Enter') sendMessage();
});

document.querySelectorAll('.aiQuick button').forEach(btn => {
  btn.addEventListener('click', () => {
    aiInput.value = btn.dataset.q;
    sendMessage();
  });
});

if (inquiryForm) {
  inquiryForm.setAttribute('action', CONFIG.formspreeEndpoint);
}

if ('speechSynthesis' in window) {
  window.speechSynthesis.onvoiceschanged = () => {};
}

setTimeout(startGreeting, 500);
</script>
</body>
</html>
